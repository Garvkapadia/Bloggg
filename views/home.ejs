<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Homepage</title>
</head>
<body>
        <%- include("./partials/nav") %>
        <div class="container mt-5">

        <div class="row">
            <% blogs.forEach(blog => { %>

                <div class="col-md-6 col-lg-3 mb-4">
                    <div class="card h-100 shadow">

                        <!-- Cover Image -->
                        <img
                            src="<%= blog.coverImage %>"
                            class="card-img-top"
                            alt="Cover Image"
                            style="height:250px; object-fit:cover; background-size: cover;"
                        >

                        <div class="card-body d-flex flex-column">

                            <!-- Title -->
                            <h4 class="card-title">
                                <%= blog.title %>
                            </h4>

                            <!-- Content -->
                            <p class="card-text">
                                <%= blog.content.substring(0,120) %>...
                            </p>

                        </div>

                        <div class="card-footer bg-white">

                            <small class="text-muted">
                                Posted on
                                <%= new Date(blog.createdAt).toLocaleString() %>
                            </small>
                              <a  class="btn btn-primary" href="/blog/<%= blog._id  %>">View more</a>  
                        </div>

                    </div>
                </div>

            <% }) %>
        </div>

    </div>
        <%- include("./partials/scripts") %>

</body>
</html>