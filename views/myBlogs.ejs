<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>My Blogs</title>
</head>
<body class="bg-light">
    <%- include("./partials/nav") %>

    <div class="container py-5">
        <h2 class="mb-4">My Blogs</h2>

        <% if (blogs.length === 0) { %>
            <div class="text-center py-5">
                <p class="mb-3" id="welcomeHeading"></p>
                <a href="/blog/add-new" class="btn btn-primary">Add your first blog</a>
            </div>
        <% } else { %>
            <div class="row g-4">
                <% blogs.forEach(blog => { %>
                    <div class="col-md-4">
                        <div class="card h-100">
                            <img src="<%= blog.coverImage %>" class="card-img-top" alt="<%= blog.title %>">
                            <div class="card-body">
                                <h5 class="card-title"><%= blog.title %></h5>
                                <a href="/blog/<%= blog._id %>" class="btn btn-outline-primary btn-sm">Read</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>


    <script>
        const text = "You haven't posted any blog yet.";
        const heading = document.getElementById("welcomeHeading");

        let index = 0;

        function typeWriter() {
            if (index < text.length) {
                heading.textContent += text.charAt(index);
                index++;
                setTimeout(typeWriter, 65); // Speed (milliseconds)
            }
        }

        window.onload = typeWriter;
    </script>
    <%- include("./partials/scripts") %>
</body>
</html>